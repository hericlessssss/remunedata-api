# Configurações de Produção (Exemplo para Coolify)

# --- Banco de Dados (PostgreSQL) ---
# Usar host 'db' conforme definido no docker-compose.prod.yml
POSTGRES_USER=remunedata_admin
POSTGRES_PASSWORD=alterar_para_senha_forte_no_coolify
POSTGRES_DB=remunedata_prod

# URL de conexão assíncrona para a API/Worker
DATABASE_URL=postgresql+asyncpg://remunedata_admin:alterar_para_senha_forte_no_coolify@db:5432/remunedata_prod

# URL de conexão síncrona para o Migrator (Alembic)
DATABASE_URL_SYNC=postgresql+psycopg2://remunedata_admin:alterar_para_senha_forte_no_coolify@db:5432/remunedata_prod

# --- Redis (Broker & Cache) ---
# Usar host 'redis' conforme definido no docker-compose.prod.yml
REDIS_PASSWORD=alterar_para_senha_forte_no_coolify
REDIS_URL=redis://:alterar_para_senha_forte_no_coolify@redis:6379/0

# --- Aplicação ---
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=["https://remunedata.com.br", "https://api.remunedata.com.br"]

# --- Hostnames Internos ---
DB_HOST=db
REDIS_HOST=redis

# --- Supabase Auth ---
