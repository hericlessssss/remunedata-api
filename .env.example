# ─── Banco de Dados ────────────────────────────────────────────────────────────
# URL de conexão assíncrona para SQLAlchemy 2.x (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/df_remuneration

# URL de conexão síncrona para Alembic (migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@postgres:5432/df_remuneration

# Credenciais do PostgreSQL (usadas pelo docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=df_remuneration

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Aplicação ─────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── API do Portal da Transparência ─────────────────────────────────────────────
# URL base da API (não deve ser alterada)
TRANSPARENCIA_API_BASE_URL=https://www.transparencia.df.gov.br/api
# Tamanho de página máximo validado (não alterar sem nova validação)
TRANSPARENCIA_PAGE_SIZE=150
# Timeout em segundos para requisições HTTP
TRANSPARENCIA_TIMEOUT_SECONDS=30
